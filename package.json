{
  "name": "vmware-mcp",
  "version": "0.1.0",
  "description": "MCP server for controlling VMware Fusion/Workstation VMs via vmrun CLI",
  "type": "module",
  "bin": {
    "vmware-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "vmware",
    "fusion",
    "workstation",
    "vmrun",
    "virtual-machine"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
